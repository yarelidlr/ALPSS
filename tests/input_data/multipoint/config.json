{
    "io": {
        "filepath": "tests/input_data/multipoint/multipoint_example.csv",
        "out_files_dir": "tests/output_data/multipoint/",
        "header_lines": 1,
        "time_to_skip": 1e-9,
        "time_to_take": 3e-06,
        "save_data": true,
        "display_plots": false
    },
    "stft": {
        "sample_rate": 128e9,
        "nperseg": 512,
        "noverlap": 435,
        "nfft": 5120,
        "window": "hann",
        "freq_min": 1500000000.0,
        "freq_max": 3500000000.0,
        "blur_kernel": [5, 5],
        "blur_sigx": 0,
        "blur_sigy": 0
    },
    "start_time": {
        "start_time_user": "iq",
        "start_time_correction": 0.0,
        "t_before": 100e-09,
        "t_after": 500e-09,
        "iq_threshold_factor": 0.4,
        "cusum_offset": 5,
        "cusum_threshold": 1000,
        "carrier_band_time": 2.5e-07
    },
    "carrier": {
        "carrier_filter_type": "gaussian_notch",
        "order": 6,
        "wid": 0.2e9,
        "t_fit_begin": 20,
        "t_fit_end": 300
    },
    "velocity": {
        "smoothing_window": 601,
        "smoothing_wid": 3,
        "smoothing_amp": 1,
        "smoothing_sigma": 1,
        "smoothing_mu": 0,
        "lam": 1550e-9,
        "theta": 0,
        "min_velocity_threshold": 25,
        "max_velocity_uncertainty_threshold": 10
    },
    "material": {
        "C0": 4540,
        "C_L": 4540,
        "density": 1730,
        "delta_rho": 9,
        "delta_C0": 23,
        "delta_lam": 8.0e-18,
        "delta_theta": 5
    },
    "spall": {
        "spall_enabled": true,
        "pb_neighbors": 400,
        "pb_idx_correction": 0,
        "rc_neighbors": 400,
        "rc_idx_correction": 0
    },
    "hel": {
        "hel_enabled": true,
        "hel_start_time_ns": 0.0,
        "hel_end_time_ns": 30.0,
        "hel_angle_threshold_deg": 45.0,
        "hel_detection_min_points": 3,
        "minimum_HEL_velocity_expected": 10.0
    },
    "uncertainty": {
        "uncert_mult": 100
    },
    "plotting": {
        "cmap": "viridis",
        "plot_figsize": [30, 10],
        "plot_dpi": 300
    }
}
